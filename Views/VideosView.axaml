<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:SevenHinos.ViewModels"
             x:Class="SevenHinos.Views.VideosView"
             x:DataType="vm:VideosViewModel"
             Background="{DynamicResource AppBg}">

    <DockPanel>

        <Border DockPanel.Dock="Top"
                Background="{DynamicResource AppSidebarBg}"
                BorderThickness="0,0,0,1"
                BorderBrush="{DynamicResource AppBorderBrush}"
                Padding="18,14">
            <StackPanel Spacing="10">
                <TextBlock Text="Vídeos"
                           FontSize="22"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource AppTextPrimary}"/>

                <TextBlock Text="{Binding MonitorStatusText}"
                           FontSize="13"
                           Foreground="{DynamicResource AppTextSecondary}"/>

                <Grid ColumnDefinitions="*,12,*,12,*">
                    <Button Grid.Column="0"
                            Click="OnAddVideoClick"
                            Padding="18,14"
                            CornerRadius="10"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Center"
                            Background="{DynamicResource AppAccent}"
                            Foreground="{DynamicResource AppAccentFg}"
                            FontSize="18"
                            FontWeight="Bold">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <TextBlock Text="▶" FontSize="20" VerticalAlignment="Center"/>
                            <TextBlock Text="Adicionar vídeo" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Grid.Column="2"
                            Click="OnRefreshMonitorsClick"
                            Padding="18,14"
                            CornerRadius="10"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Center"
                            Background="{DynamicResource AppNavButtonBg}"
                            Foreground="{DynamicResource AppTextPrimary}"
                            FontSize="16"
                            FontWeight="SemiBold">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <TextBlock Text="⟳" FontSize="18" VerticalAlignment="Center"/>
                            <TextBlock Text="Atualizar telas" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Grid.Column="4"
                            Command="{Binding StopAllOutputsCommand}"
                            Padding="18,14"
                            CornerRadius="10"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Center"
                            Background="#5A2222"
                            Foreground="#FFD4D4"
                            FontSize="16"
                            FontWeight="SemiBold"
                            IsEnabled="{Binding IsAnyVideoPlaying}">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <TextBlock Text="■" FontSize="18" VerticalAlignment="Center"/>
                            <TextBlock Text="Parar exibição" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </Grid>

                <Grid ColumnDefinitions="*,10,190">
                    <TextBox Grid.Column="0"
                             Text="{Binding NewCategoryName}"
                             Watermark="Nova categoria..."
                             FontSize="14"
                             Padding="12,10"
                             CornerRadius="8"/>
                    <Button Grid.Column="2"
                            Content="+ Criar categoria"
                            Command="{Binding CreateCategoryCommand}"
                            Padding="14,10"
                            CornerRadius="8"
                            FontSize="14"
                            FontWeight="SemiBold"
                            Background="{DynamicResource AppNavButtonBg}"
                            Foreground="{DynamicResource AppTextPrimary}"/>
                </Grid>

                <Grid ColumnDefinitions="150,10,*">
                    <TextBlock Grid.Column="0"
                               Text="Filtrar categoria"
                               VerticalAlignment="Center"
                               FontSize="13"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource AppTextSecondary}"/>
                    <ComboBox Grid.Column="2"
                              ItemsSource="{Binding CategoryFilters}"
                              SelectedItem="{Binding SelectedCategoryFilter}"
                              Padding="10,8"
                              CornerRadius="8">
                        <ComboBox.ItemTemplate>
                            <DataTemplate DataType="vm:CategoryFilterItemViewModel">
                                <TextBlock Text="{Binding Name}"/>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                </Grid>

                <Border Background="{DynamicResource AppBg}"
                        BorderThickness="1"
                        BorderBrush="{DynamicResource AppBorderBrush}"
                        CornerRadius="10"
                        Padding="12"
                        IsVisible="{Binding HasManageableCategories}">
                    <StackPanel Spacing="8">
                        <TextBlock Text="Editar categoria e preset de telas"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource AppTextPrimary}"/>

                        <Grid ColumnDefinitions="*,10,180">
                            <ComboBox Grid.Column="0"
                                      ItemsSource="{Binding CategoryManagementOptions}"
                                      SelectedItem="{Binding SelectedCategoryForManagement}"
                                      Padding="8,6"
                                      CornerRadius="6">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate DataType="vm:CategoryOptionViewModel">
                                        <TextBlock Text="{Binding Name}"/>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>

                            <Button Grid.Column="2"
                                    Content="Salvar categoria"
                                    Command="{Binding SaveSelectedCategoryCommand}"
                                    IsEnabled="{Binding CanEditSelectedCategory}"
                                    Padding="10,8"
                                    CornerRadius="6"
                                    FontWeight="SemiBold"
                                    Background="{DynamicResource AppNavButtonBg}"
                                    Foreground="{DynamicResource AppTextPrimary}"/>
                        </Grid>

                        <Grid ColumnDefinitions="*,10,180">
                            <TextBox Grid.Column="0"
                                     Text="{Binding CategoryEditorName}"
                                     Watermark="Nome da categoria"
                                     IsEnabled="{Binding CanEditSelectedCategory}"
                                     Padding="8,6"
                                     CornerRadius="6"/>

                            <Button Grid.Column="2"
                                    Content="Excluir categoria"
                                    Command="{Binding DeleteSelectedCategoryCommand}"
                                    IsEnabled="{Binding CanEditSelectedCategory}"
                                    Padding="10,8"
                                    CornerRadius="6"
                                    FontWeight="SemiBold"
                                    Background="#5A2222"
                                    Foreground="#FFD4D4"/>
                        </Grid>

                        <TextBlock Text="Preset de telas para essa categoria"
                                   FontSize="12"
                                   Foreground="{DynamicResource AppTextSecondary}"/>

                        <ItemsControl ItemsSource="{Binding CategoryPresetMonitorOptions}"
                                      IsEnabled="{Binding CanEditSelectedCategory}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel Orientation="Horizontal"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="vm:VideoMonitorSelectionViewModel">
                                    <CheckBox Content="{Binding Label}"
                                              IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                              Margin="0,0,10,8"
                                              FontSize="13"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Border>

        <Border DockPanel.Dock="Top"
                Background="{DynamicResource AppSidebarBg}"
                BorderThickness="0,0,0,1"
                BorderBrush="{DynamicResource AppBorderBrush}"
                Padding="18,10">
            <TextBlock Text="{Binding StatusText}"
                       FontSize="13"
                       Foreground="{DynamicResource AppTextSecondary}"
                       TextWrapping="Wrap"/>
        </Border>

        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      Padding="14">
            <StackPanel Spacing="12">

                <Border IsVisible="{Binding HasVideos, Converter={x:Static BoolConverters.Not}}"
                        Background="{DynamicResource AppSidebarBg}"
                        BorderThickness="1"
                        BorderBrush="{DynamicResource AppBorderBrush}"
                        CornerRadius="10"
                        Padding="20">
                    <StackPanel Spacing="8">
                        <TextBlock Text="Nenhum vídeo adicionado"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource AppTextPrimary}"/>
                        <TextBlock Text="Use o botão Adicionar vídeo, organize por categoria e marque as telas desejadas."
                                   FontSize="14"
                                   Foreground="{DynamicResource AppTextSecondary}"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

                <ItemsControl ItemsSource="{Binding Videos}"
                              IsVisible="{Binding HasVideos}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="vm:VideoCardViewModel">
                            <Border Background="{DynamicResource AppSidebarBg}"
                                    BorderThickness="1"
                                    BorderBrush="{DynamicResource AppBorderBrush}"
                                    CornerRadius="10"
                                    Padding="16"
                                    Margin="0,0,0,8">
                                <StackPanel Spacing="10">
                                    <Grid ColumnDefinitions="*,Auto">
                                        <StackPanel Grid.Column="0" Spacing="4">
                                            <TextBlock Text="{Binding VideoName}"
                                                       FontSize="18"
                                                       FontWeight="SemiBold"
                                                       Foreground="{DynamicResource AppTextPrimary}"
                                                       TextWrapping="Wrap"/>
                                            <TextBlock Text="{Binding FilePath}"
                                                       FontSize="12"
                                                       Foreground="{DynamicResource AppTextMuted}"
                                                       TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Text="{Binding SelectedCategoryName, StringFormat='Categoria: {0}'}"
                                                       FontSize="13"
                                                       FontWeight="SemiBold"
                                                       Foreground="{DynamicResource AppTextSecondary}"/>
                                            <TextBlock Text="{Binding SelectedMonitorsSummary, StringFormat='Telas: {0}'}"
                                                       FontSize="13"
                                                       FontWeight="SemiBold"
                                                       Foreground="{DynamicResource AppAccent}"/>
                                        </StackPanel>

                                        <StackPanel Grid.Column="1" Spacing="6" Margin="12,0,0,0">
                                            <Button Content="▲"
                                                    Command="{Binding MoveUpCommand}"
                                                    Width="34"
                                                    Height="30"
                                                    CornerRadius="6"
                                                    Background="{DynamicResource AppNavButtonBg}"
                                                    Foreground="{DynamicResource AppTextPrimary}"
                                                    ToolTip.Tip="Mover vídeo para cima"/>
                                            <Button Content="▼"
                                                    Command="{Binding MoveDownCommand}"
                                                    Width="34"
                                                    Height="30"
                                                    CornerRadius="6"
                                                    Background="{DynamicResource AppNavButtonBg}"
                                                    Foreground="{DynamicResource AppTextPrimary}"
                                                    ToolTip.Tip="Mover vídeo para baixo"/>
                                        </StackPanel>
                                    </Grid>

                                    <Border Background="#224466"
                                            CornerRadius="6"
                                            Padding="10,5"
                                            HorizontalAlignment="Left"
                                            IsVisible="{Binding IsPlaying}">
                                        <TextBlock Text="EXIBINDO AGORA"
                                                   FontSize="11"
                                                   FontWeight="Bold"
                                                   Foreground="#99D6FF"/>
                                    </Border>

                                    <Border Background="{DynamicResource AppBg}"
                                            BorderThickness="1"
                                            BorderBrush="{DynamicResource AppBorderBrush}"
                                            CornerRadius="8"
                                            Padding="12"
                                            IsEnabled="{Binding IsEditing}">
                                        <StackPanel Spacing="8">
                                            <TextBlock Text="Categoria"
                                                       FontSize="13"
                                                       FontWeight="SemiBold"
                                                       Foreground="{DynamicResource AppTextPrimary}"/>
                                            <ComboBox ItemsSource="{Binding CategoryOptions}"
                                                      SelectedItem="{Binding SelectedCategoryOption, Mode=TwoWay}"
                                                      Padding="8,6"
                                                      CornerRadius="6">
                                                <ComboBox.ItemTemplate>
                                                    <DataTemplate DataType="vm:CategoryOptionViewModel">
                                                        <TextBlock Text="{Binding Name}"/>
                                                    </DataTemplate>
                                                </ComboBox.ItemTemplate>
                                            </ComboBox>

                                            <Button Content="Aplicar preset da categoria"
                                                    Command="{Binding ApplyCategoryPresetCommand}"
                                                    Padding="10,8"
                                                    CornerRadius="6"
                                                    FontSize="13"
                                                    FontWeight="SemiBold"
                                                    Background="{DynamicResource AppNavButtonBg}"
                                                    Foreground="{DynamicResource AppTextPrimary}"/>

                                            <TextBlock Text="Telas detectadas"
                                                       FontSize="14"
                                                       FontWeight="SemiBold"
                                                       Foreground="{DynamicResource AppTextPrimary}"/>

                                            <ItemsControl ItemsSource="{Binding MonitorOptions}">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <WrapPanel Orientation="Horizontal"/>
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate DataType="vm:VideoMonitorSelectionViewModel">
                                                        <CheckBox Content="{Binding Label}"
                                                                  IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                                                  Margin="0,0,10,8"
                                                                  FontSize="14"/>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </Border>

                                    <TextBlock Text="Clique em Editar para marcar ou desmarcar as telas."
                                               IsVisible="{Binding IsEditing, Converter={x:Static BoolConverters.Not}}"
                                               FontSize="12"
                                               Foreground="{DynamicResource AppTextSecondary}"/>

                                    <Grid ColumnDefinitions="*,8,*,8,*,8,*">
                                        <Button Grid.Column="0"
                                                Content="{Binding EditButtonText}"
                                                Command="{Binding ToggleEditCommand}"
                                                Padding="14,10"
                                                CornerRadius="8"
                                                HorizontalAlignment="Stretch"
                                                HorizontalContentAlignment="Center"
                                                FontSize="15"
                                                FontWeight="SemiBold"
                                                Background="{DynamicResource AppNavButtonBg}"
                                                Foreground="{DynamicResource AppTextPrimary}"/>

                                        <Button Grid.Column="2"
                                                Content="▶ Exibir"
                                                Command="{Binding PlayCommand}"
                                                Padding="14,10"
                                                CornerRadius="8"
                                                HorizontalAlignment="Stretch"
                                                HorizontalContentAlignment="Center"
                                                FontSize="15"
                                                FontWeight="SemiBold"
                                                Background="#1E4A2E"
                                                Foreground="#D2FFD8"/>

                                        <Button Grid.Column="4"
                                                Content="■ Parar"
                                                Command="{Binding StopCommand}"
                                                IsEnabled="{Binding IsPlaying}"
                                                Padding="14,10"
                                                CornerRadius="8"
                                                HorizontalAlignment="Stretch"
                                                HorizontalContentAlignment="Center"
                                                FontSize="15"
                                                FontWeight="SemiBold"
                                                Background="{DynamicResource AppNavButtonBg}"
                                                Foreground="{DynamicResource AppTextPrimary}"/>

                                        <Button Grid.Column="6"
                                                Content="✖ Remover"
                                                Command="{Binding RemoveCommand}"
                                                Padding="14,10"
                                                CornerRadius="8"
                                                HorizontalAlignment="Stretch"
                                                HorizontalContentAlignment="Center"
                                                FontSize="15"
                                                FontWeight="SemiBold"
                                                Background="#5A2222"
                                                Foreground="#FFD4D4"/>
                                    </Grid>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

            </StackPanel>
        </ScrollViewer>

    </DockPanel>
</UserControl>
