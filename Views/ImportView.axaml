<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:SevenHinos.ViewModels"
             x:Class="SevenHinos.Views.ImportView"
             x:DataType="vm:ImportViewModel">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel MaxWidth="700"
                    Margin="24,20"
                    HorizontalAlignment="Left"
                    Spacing="0">

            <TextBlock Text="Importar hinos"
                       FontSize="26"
                       FontWeight="Bold"
                       Foreground="{DynamicResource AppTextPrimary}"
                       Margin="0,0,0,6"/>
            <TextBlock Text="Escolha a origem da importação. Todo o processo funciona offline e usa apenas os dados disponíveis nesta máquina."
                       FontSize="13"
                       Foreground="{DynamicResource AppTextSecondary}"
                       TextWrapping="Wrap"
                       Margin="0,0,0,20"/>

            <Grid ColumnDefinitions="*,12,*" Margin="0,0,0,18">
                <Button Grid.Column="0"
                        Command="{Binding SelectNativeLibrarySourceCommand}"
                        Padding="16,14"
                        CornerRadius="8"
                        FontSize="14"
                        FontWeight="SemiBold"
                        Background="#1A3355"
                        Foreground="#88CCFF"
                        IsEnabled="{Binding IsImporting, Converter={x:Static BoolConverters.Not}}">
                    <StackPanel Spacing="4">
                        <TextBlock Text="Importar da biblioteca nativa"
                                   FontSize="15"
                                   FontWeight="SemiBold"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="Usa o catálogo local incluído com o aplicativo"
                                   FontSize="11"
                                   Foreground="#A8CBEA"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <Button Grid.Column="2"
                        Command="{Binding SelectLouvorJaSourceCommand}"
                        Padding="16,14"
                        CornerRadius="8"
                        FontSize="14"
                        FontWeight="SemiBold"
                        Background="{DynamicResource AppNavButtonBg}"
                        Foreground="{DynamicResource AppTextPrimary}"
                        IsEnabled="{Binding IsImporting, Converter={x:Static BoolConverters.Not}}">
                    <StackPanel Spacing="4">
                        <TextBlock Text="Importar da instalação do LouvorJA"
                                   FontSize="15"
                                   FontWeight="SemiBold"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="Lê a base já instalada no computador"
                                   FontSize="11"
                                   Foreground="{DynamicResource AppTextSecondary}"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </Grid>

            <Border Background="{DynamicResource AppSidebarBg}"
                    CornerRadius="10"
                    BorderThickness="1"
                    BorderBrush="{DynamicResource AppBorderBrush}"
                    Padding="16"
                    Margin="0,0,0,18">
                <StackPanel Spacing="8">
                    <TextBlock Text="{Binding SelectedSourceTitle}"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource AppTextPrimary}"/>
                    <TextBlock Text="{Binding SelectedSourceDescription}"
                               FontSize="12"
                               Foreground="{DynamicResource AppTextSecondary}"
                               TextWrapping="Wrap"/>

                    <Border CornerRadius="6"
                            Padding="10,8"
                            Background="#1A2A3A">
                        <TextBlock Text="{Binding SourceAvailabilityText}"
                                   FontSize="12"
                                   Foreground="#A8CBEA"
                                   TextWrapping="Wrap"/>
                    </Border>
                </StackPanel>
            </Border>

            <Border Background="{DynamicResource AppSidebarBg}"
                    CornerRadius="10"
                    BorderThickness="1"
                    BorderBrush="{DynamicResource AppBorderBrush}"
                    Padding="16"
                    Margin="0,0,0,18"
                    IsVisible="{Binding IsNativeLibrarySelected}">
                <StackPanel Spacing="8">
                    <TextBlock Text="Arquivo da biblioteca nativa"
                               FontSize="12"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource AppTextSecondary}"/>
                    <TextBox Text="{Binding NativeLibraryPath}"
                             IsReadOnly="True"
                             FontSize="13"
                             Padding="10,8"
                             CornerRadius="6"/>
                    <TextBlock Text="Os hinos serão gerados a partir do catálogo offline do próprio 7Hinos. Se os áudios já estiverem no computador, os caminhos serão vinculados automaticamente."
                               FontSize="12"
                               Foreground="{DynamicResource AppTextSecondary}"
                               TextWrapping="Wrap"/>
                </StackPanel>
            </Border>

            <Border Background="{DynamicResource AppSidebarBg}"
                    CornerRadius="10"
                    BorderThickness="1"
                    BorderBrush="{DynamicResource AppBorderBrush}"
                    Padding="16"
                    Margin="0,0,0,18"
                    IsVisible="{Binding IsLouvorJaSelected}">
                <StackPanel Spacing="10">
                    <TextBlock Text="Pasta da instalação do LouvorJA"
                               FontSize="12"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource AppTextSecondary}"/>

                    <Grid ColumnDefinitions="*,10,Auto,10,Auto">
                        <TextBox Grid.Column="0"
                                 Text="{Binding LouvorJaFolder}"
                                 FontSize="13"
                                 Padding="10,8"
                                 CornerRadius="6"
                                 IsEnabled="{Binding IsImporting, Converter={x:Static BoolConverters.Not}}"/>
                        <Button Grid.Column="2"
                                Content="Detectar"
                                Command="{Binding AutoDetectLouvorJaCommand}"
                                Padding="12,8"
                                CornerRadius="6"
                                Background="{DynamicResource AppNavButtonBg}"
                                Foreground="{DynamicResource AppTextPrimary}"
                                IsEnabled="{Binding IsImporting, Converter={x:Static BoolConverters.Not}}"/>
                        <Button Grid.Column="4"
                                Content="Selecionar pasta"
                                Click="OnBrowseLouvorJaFolderClick"
                                Padding="12,8"
                                CornerRadius="6"
                                Background="{DynamicResource AppNavButtonBg}"
                                Foreground="{DynamicResource AppTextPrimary}"
                                IsEnabled="{Binding IsImporting, Converter={x:Static BoolConverters.Not}}"/>
                    </Grid>

                    <TextBlock Text="Banco detectado"
                               FontSize="12"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource AppTextSecondary}"/>
                    <TextBox Text="{Binding LouvorJaDbPath}"
                             IsReadOnly="True"
                             FontSize="12"
                             Padding="10,8"
                             CornerRadius="6"/>

                    <TextBlock Text="Pasta de áudios detectada"
                               FontSize="12"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource AppTextSecondary}"/>
                    <TextBox Text="{Binding LouvorJaMusicasFolder}"
                             IsReadOnly="True"
                             FontSize="12"
                             Padding="10,8"
                             CornerRadius="6"/>
                </StackPanel>
            </Border>

            <Border Background="#1A2A3A"
                    CornerRadius="8"
                    Padding="14,12"
                    BorderThickness="1"
                    BorderBrush="#2A4A6A"
                    Margin="0,0,0,20">
                <StackPanel Spacing="4">
                    <TextBlock Text="O que será importado"
                               FontSize="13"
                               FontWeight="SemiBold"
                               Foreground="#89B4FA"/>
                    <TextBlock TextWrapping="Wrap" FontSize="12" Foreground="#AAAAAA">
                        O 7Hinos ignora automaticamente hinos já existentes com o mesmo título e coletânea.
                        A origem LouvorJA também importa letras e slides. A biblioteca nativa importa o catálogo
                        local do aplicativo e vincula áudios quando os arquivos já estiverem disponíveis.
                    </TextBlock>
                </StackPanel>
            </Border>

                <Button Content="Importar hinos"
                    Command="{Binding ImportCommand}"
                    HorizontalAlignment="Left"
                    Padding="20,12"
                    CornerRadius="8"
                    FontSize="15"
                    FontWeight="SemiBold"
                    Background="#4477FF"
                    Foreground="White"
                    IsVisible="{Binding IsImporting, Converter={x:Static BoolConverters.Not}}"
                    Margin="0,0,0,20"/>

            <StackPanel Spacing="8"
                        IsVisible="{Binding IsImporting}"
                        Margin="0,0,0,20">
                <ProgressBar Value="{Binding Progress}"
                             Minimum="0" Maximum="100"
                             Height="8"
                             CornerRadius="4"/>
                <TextBlock Text="{Binding StatusText}"
                           FontSize="12"
                           Foreground="{DynamicResource AppTextSecondary}"
                           TextTrimming="CharacterEllipsis"/>
            </StackPanel>

            <StackPanel Spacing="12"
                        IsVisible="{Binding IsDone}">

                <Border Background="#1A2A1A"
                        CornerRadius="8"
                        Padding="16,12"
                        BorderThickness="1"
                        BorderBrush="#2A5A2A">
                    <TextBlock Text="{Binding ResultText}"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Foreground="#AAFFAA"
                               TextWrapping="Wrap"/>
                </Border>

                <StackPanel Spacing="8"
                            IsVisible="{Binding HasErrors}">
                    <TextBlock Text="Erros encontrados:"
                               FontSize="12"
                               FontWeight="SemiBold"
                               Foreground="#FFAAAA"/>
                    <Border Background="#1A0000"
                            CornerRadius="6"
                            Padding="12"
                            MaxHeight="160">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding ErrorLines}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding}"
                                                   FontSize="11"
                                                   Foreground="#FF8888"
                                                   TextWrapping="Wrap"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Border>
                </StackPanel>
            </StackPanel>

            <StackPanel Orientation="Horizontal"
                        Spacing="10"
                        Margin="0,18,0,0">
                <Button Content="Limpar resultado"
                        Command="{Binding ResetResultCommand}"
                        HorizontalAlignment="Left"
                        Padding="14,8"
                        CornerRadius="6"
                        FontSize="13"
                        Background="{DynamicResource AppNavButtonBg}"
                        Foreground="{DynamicResource AppTextSecondary}"/>
                <Button Content="Fechar"
                        Click="OnCloseClick"
                        HorizontalAlignment="Left"
                        Padding="14,8"
                        CornerRadius="6"
                        FontSize="13"
                        Background="Transparent"
                        Foreground="{DynamicResource AppTextSecondary}"/>
            </StackPanel>

        </StackPanel>
    </ScrollViewer>

</UserControl>
