<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="using:SevenHinos.Views"
        x:Class="SevenHinos.Views.ImportWindow"
        Title="Importar hinos"
        Width="760"
        Height="680"
        MinWidth="680"
        MinHeight="560"
        CanResize="False"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource AppBg}">

    <views:ImportView/>
</Window>