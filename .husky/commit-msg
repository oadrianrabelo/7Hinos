#!/bin/sh
. "$(dirname "$0")/_/husky.sh"

commit_msg=$(cat "$1")
pattern="^(feat|fix|chore|docs|style|refactor|test|ci)(\(.+\))?: .{1,100}$"

if ! echo "$commit_msg" | grep -qE "$pattern"; then
  echo ""
  echo "❌ Commit inválido: '$commit_msg'"
  echo ""
  echo "✅ Use o padrão: tipo(escopo): descrição"
  echo "   Exemplos:"
  echo "   feat(player): adicionar reprodução de vídeo"
  echo "   fix(hymns): corrigir busca por número"
  echo "   chore: atualizar dependências"
  echo ""
  exit 1
fi

