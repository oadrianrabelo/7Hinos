<?xml version="1.0" encoding="utf-8"?>
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
  xmlns:ui="http://wixtoolset.org/schemas/v4/wxs/ui">
  <?include Generated\BuildVariables.wxi?>

  <Package Name="7Hinos"
           Manufacturer="7Hinos"
           Version="$(ProductVersion)"
           Language="1046"
           UpgradeCode="9D4D77E7-1E5C-40D4-B659-8E62AB8D2ACD"
           Scope="perMachine"
           InstallerVersion="500"
           Compressed="yes"
           Codepage="65001">

    <MajorUpgrade DowngradeErrorMessage="Ja existe uma versao mais recente do 7Hinos instalada." />
    <MediaTemplate EmbedCab="yes" />

    <Property Id="WIXUI_EXITDIALOGOPTIONALCHECKBOXTEXT"
              Value="Abrir 7Hinos ao finalizar a instalacao." />
    <SetProperty Id="WixShellExecTarget"
           Value="[INSTALLFOLDER]SevenHinos.exe"
                 Before="ExecuteAction"
           Sequence="ui" />

    <CustomAction Id="LaunchApplication"
                  BinaryRef="Wix4UtilCA_$(sys.BUILDARCHSHORT)"
                  DllEntry="WixShellExec"
                  Execute="immediate"
                  Return="ignore" />

    <ui:WixUI Id="WixUI_InstallDir"
              InstallDirectory="INSTALLFOLDER" />

    <UI>
      <Publish Dialog="ExitDialog"
               Control="Finish"
               Event="DoAction"
               Value="LaunchApplication"
               Condition="WIXUI_EXITDIALOGOPTIONALCHECKBOX = 1 AND NOT Installed" />
    </UI>

    <StandardDirectory Id="ProgramFiles64Folder">
      <Directory Id="INSTALLFOLDER" Name="7Hinos" />
    </StandardDirectory>

    <StandardDirectory Id="ProgramMenuFolder">
      <Directory Id="AppProgramMenuDir" Name="7Hinos" />
    </StandardDirectory>

    <StandardDirectory Id="DesktopFolder" />

    <Feature Id="MainFeature" Title="7Hinos" Level="1">
      <Files Directory="INSTALLFOLDER" Include="$(PublishDir)\**" />
      <ComponentRef Id="StartMenuShortcutComponent" />
      <ComponentRef Id="DesktopShortcutComponent" />
    </Feature>
  </Package>

  <Fragment>
    <Component Id="StartMenuShortcutComponent"
               Directory="AppProgramMenuDir"
               Guid="*">
      <Shortcut Id="StartMenuShortcut"
                Name="7Hinos"
                Description="Abrir 7Hinos"
                Target="[INSTALLFOLDER]SevenHinos.exe"
                WorkingDirectory="INSTALLFOLDER" />
      <RemoveFolder Id="RemoveProgramMenuDir" On="uninstall" />
      <RegistryValue Root="HKCU"
                     Key="Software\7Hinos"
                     Name="StartMenuShortcut"
                     Type="integer"
                     Value="1"
                     KeyPath="yes" />
    </Component>

    <Component Id="DesktopShortcutComponent"
               Directory="DesktopFolder"
               Guid="*">
      <Shortcut Id="DesktopShortcut"
                Name="7Hinos"
                Description="Abrir 7Hinos"
                Target="[INSTALLFOLDER]SevenHinos.exe"
                WorkingDirectory="INSTALLFOLDER" />
      <RegistryValue Root="HKCU"
                     Key="Software\7Hinos"
                     Name="DesktopShortcut"
                     Type="integer"
                     Value="1"
                     KeyPath="yes" />
    </Component>
  </Fragment>
</Wix>